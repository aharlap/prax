{
  "name": "@praxity/tokens",
  "version": "0.0.0",
  "description": "Prax design tokens for runtime blocks and generated pages.",
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": [
    "./dist/tokens.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tokens.css": "./dist/tokens.css",
    "./tokens.json": "./dist/tokens.json",
    "./design.md": "./dist/design.md"
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "rm -rf dist && mkdir -p dist && cp tokens.css tokens.json design.md dist/ && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "node --test dist/**/*.test.js"
  }
}
