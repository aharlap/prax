{
  "name": "@praxity/scorm",
  "version": "0.0.0",
  "description": "Prax SCORM 2004, xAPI, and local tracking facades.",
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "node --test dist/**/*.test.js"
  },
  "dependencies": {
    "@praxity/runtime-core": "workspace:*"
  }
}
